---
// Brand-gradient placeholder. Pure CSS — no SVG, no filter:blur, no shared IDs.
//
// This used to be an inline SVG with feGaussianBlur, which forced the browser
// to rasterize 18 separate filter graphs on first paint and gave us ~790ms of
// total blocking time on Lighthouse. CSS radial-gradients composite on the GPU,
// drop TBT by ~60%, and have no side-effects from filter / display:none either.
//
// Theme-aware via the same --placeholder-* CSS variables defined in global.css.
---
<div class="placeholder" aria-hidden="true"></div>

<style>
  .placeholder {
    width: 100%;
    height: 100%;
    background-color: var(--placeholder-bg);
    background-image:
      radial-gradient(
        ellipse 60% 75% at 20% 20%,
        color-mix(in oklab, var(--color-red-50) calc(var(--placeholder-red-op, 0.85) * 100%), transparent),
        transparent 60%
      ),
      radial-gradient(
        ellipse 55% 70% at 55% -5%,
        color-mix(in oklab, var(--color-orange-50) calc(var(--placeholder-orange-op, 0.7) * 100%), transparent),
        transparent 70%
      ),
      radial-gradient(
        ellipse 60% 75% at 85% 35%,
        color-mix(in oklab, var(--color-purple-70) calc(var(--placeholder-purple-op, 0.85) * 100%), transparent),
        transparent 65%
      ),
      radial-gradient(
        ellipse 80% 70% at 50% 105%,
        color-mix(in oklab, var(--placeholder-vig-color) calc(var(--placeholder-vig-op, 0.85) * 100%), transparent),
        transparent 100%
      );
  }
</style>

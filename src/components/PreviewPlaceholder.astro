---
// Inline brand-gradient placeholder. Used as the default card preview when an
// integration doesn't define `preview` in labs.json.
//
// All theme behavior comes from --placeholder-* CSS variables defined in
// global.css under each [data-theme] block, so this file is theme-agnostic.
//
// Each instance generates a UNIQUE id namespace for its gradient/filter defs.
// Without this, every card would share the same `ph-red` / `ph-orange` etc.
// IDs, and when filtering hides the first card (display:none), Chromium/WebKit
// fail to resolve `url(#id)` references that target an element inside a
// hidden subtree — making the gradients vanish from every other card.

const k = crypto.randomUUID().slice(0, 8);
const id = (n: string) => `${n}-${k}`;
---
<svg
  class="placeholder"
  viewBox="0 0 1200 630"
  preserveAspectRatio="xMidYMid slice"
  aria-hidden="true"
>
  <defs>
    <radialGradient id={id("ph-red")} cx="20%" cy="20%" r="60%">
      <stop offset="0%" class="ph-stop-red" />
      <stop offset="60%" class="ph-stop-fade" />
    </radialGradient>
    <radialGradient id={id("ph-orange")} cx="55%" cy="0%" r="55%">
      <stop offset="0%" class="ph-stop-orange" />
      <stop offset="70%" class="ph-stop-fade" />
    </radialGradient>
    <radialGradient id={id("ph-purple")} cx="85%" cy="35%" r="60%">
      <stop offset="0%" class="ph-stop-purple" />
      <stop offset="65%" class="ph-stop-fade" />
    </radialGradient>
    <radialGradient id={id("ph-vignette")} cx="50%" cy="105%" r="80%">
      <stop offset="0%" class="ph-stop-vignette" />
      <stop offset="100%" class="ph-stop-fade" />
    </radialGradient>
    <pattern id={id("ph-grid")} width="56" height="56" patternUnits="userSpaceOnUse">
      <path d="M56 0H0V56" fill="none" class="ph-grid-line" stroke-width="1" />
    </pattern>
    <filter id={id("ph-blur")}><feGaussianBlur stdDeviation="40" /></filter>
  </defs>

  <rect width="1200" height="630" class="ph-bg" />
  <rect width="1200" height="630" fill={`url(#${id("ph-grid")})`} />
  <g filter={`url(#${id("ph-blur")})`}>
    <rect width="1200" height="630" fill={`url(#${id("ph-red")})`} />
    <rect width="1200" height="630" fill={`url(#${id("ph-orange")})`} />
    <rect width="1200" height="630" fill={`url(#${id("ph-purple")})`} />
    <rect width="1200" height="630" fill={`url(#${id("ph-vignette")})`} />
  </g>
</svg>

<style>
  .placeholder {
    display: block;
    width: 100%;
    height: 100%;
  }
  .ph-bg            { fill: var(--placeholder-bg); }
  .ph-grid-line     { stroke: var(--placeholder-grid); }
  .ph-stop-red      { stop-color: var(--color-red-50);    stop-opacity: var(--placeholder-red-op); }
  .ph-stop-orange   { stop-color: var(--color-orange-50); stop-opacity: var(--placeholder-orange-op); }
  .ph-stop-purple   { stop-color: var(--color-purple-70); stop-opacity: var(--placeholder-purple-op); }
  .ph-stop-vignette { stop-color: var(--placeholder-vig-color); stop-opacity: var(--placeholder-vig-op); }
  .ph-stop-fade     { stop-color: transparent; stop-opacity: 0; }
</style>

---
// Tri-mode theme switcher: dark / light / system.
// State lives on <html data-theme="..."> set pre-paint by an inline script in BaseLayout.
// This component renders the segmented control + binds clicks.
---
<div
  class="theme-switcher inline-flex items-center gap-0.5 rounded-full border p-0.5"
  style="border-color: var(--border); background: var(--bg-elevated);"
  role="group"
  aria-label="Color theme"
>
  <button
    type="button"
    data-theme-set="light"
    class="theme-btn"
    aria-label="Light theme"
    title="Light"
    data-track="theme_change"
    data-track-theme="light"
  >
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="4" />
      <path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
    </svg>
  </button>
  <button
    type="button"
    data-theme-set="system"
    class="theme-btn"
    aria-label="System theme"
    title="System"
    data-track="theme_change"
    data-track-theme="system"
  >
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="3" y="4" width="18" height="13" rx="2" />
      <path d="M9 21h6M12 17v4" />
    </svg>
  </button>
  <button
    type="button"
    data-theme-set="dark"
    class="theme-btn"
    aria-label="Dark theme"
    title="Dark"
    data-track="theme_change"
    data-track-theme="dark"
  >
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" />
    </svg>
  </button>
</div>

<style>
  .theme-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 999px;
    color: var(--fg-muted);
    background: transparent;
    border: 0;
    cursor: pointer;
    transition: color 0.15s ease, background 0.15s ease;
  }
  .theme-btn:hover { color: var(--fg); }
  /* Active-state is driven by the `[data-theme]` attribute on <html> matching
   * the button's `data-theme-set` value. Visual treatment is identical to the
   * `aria-pressed="true"` styling — keeping both selectors lets the
   * accessibility-tree state mirror the visible state. */
  .theme-btn[aria-pressed="true"],
  [data-theme="light"] .theme-btn[data-theme-set="light"],
  [data-theme="dark"] .theme-btn[data-theme-set="dark"],
  [data-theme="system"] .theme-btn[data-theme-set="system"] {
    background: var(--bg-card);
    color: var(--fg);
    box-shadow: inset 0 0 0 1px var(--border);
  }
</style>

<script is:inline>
  (function () {
    const root = document.documentElement;
    const buttons = document.querySelectorAll(".theme-btn");
    const refreshPressed = () => {
      const current = root.getAttribute("data-theme") ?? "system";
      buttons.forEach((btn) => {
        const set = btn.getAttribute("data-theme-set");
        btn.setAttribute("aria-pressed", set === current ? "true" : "false");
      });
    };
    refreshPressed();
    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const next = btn.getAttribute("data-theme-set");
        if (!next) return;
        root.setAttribute("data-theme", next);
        try { localStorage.setItem("bb-theme", next); } catch (e) {}
        refreshPressed();
      });
    });
  })();
</script>

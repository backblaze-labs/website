---
// Theme switcher: light / system / dark, collapsed into a compact dropdown so it
// takes minimal space in the nav. State lives on <html data-theme="..."> set
// pre-paint by an inline script in BaseLayout; the trigger shows the active icon.
const icons: Record<string, string> = {
  light: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4" /><path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" /></svg>`,
  system: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="13" rx="2" /><path d="M9 21h6M12 17v4" /></svg>`,
  dark: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" /></svg>`,
};
const options = [
  { value: "light", label: "Light" },
  { value: "system", label: "System" },
  { value: "dark", label: "Dark" },
];
---
<div class="theme-switcher relative inline-flex" data-theme-switcher>
  <button
    type="button"
    class="theme-trigger inline-flex items-center gap-1 rounded-full border"
    style="border-color: var(--border); background: var(--bg-elevated);"
    aria-haspopup="true"
    aria-expanded="false"
    aria-label="Color theme"
    data-theme-trigger
  >
    {options.map((o) => (
      <span class={`ts-icon ts-icon--${o.value}`} set:html={icons[o.value]} />
    ))}
    <svg class="ts-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6" /></svg>
  </button>

  <div class="theme-menu" role="menu" aria-label="Color theme" data-theme-menu hidden>
    {options.map((o) => (
      <button
        type="button"
        role="menuitemradio"
        aria-checked="false"
        class="theme-option"
        data-theme-set={o.value}
        data-track="theme_change"
        data-track-theme={o.value}
      >
        <span class="theme-option-icon" set:html={icons[o.value]} />
        <span>{o.label}</span>
      </button>
    ))}
  </div>
</div>

<style>
  .theme-switcher { position: relative; }

  .theme-trigger {
    padding: 0.45rem 0.6rem;
    color: var(--fg-muted);
    cursor: pointer;
    line-height: 0;
    transition: color 0.15s ease, background 0.15s ease;
  }
  .theme-trigger:hover { color: var(--fg); }

  .ts-icon { display: none; line-height: 0; }
  /* `[data-theme]` lives on <html>, outside this component — :global keeps Astro
     from scoping the ancestor selector (which would never match the root). */
  :global([data-theme="light"]) .ts-icon--light,
  :global([data-theme="system"]) .ts-icon--system,
  :global([data-theme="dark"]) .ts-icon--dark { display: inline-flex; }

  .ts-chevron { opacity: 0.7; transition: transform 0.18s ease; }
  .theme-trigger[aria-expanded="true"] .ts-chevron { transform: rotate(180deg); }

  .theme-menu {
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 0;
    z-index: 60;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 9rem;
    padding: 0.3rem;
    border-radius: 0.75rem;
    border: 1px solid var(--border);
    background: color-mix(in oklab, var(--bg) 92%, transparent);
    backdrop-filter: blur(16px) saturate(150%);
    -webkit-backdrop-filter: blur(16px) saturate(150%);
    box-shadow: 0 14px 34px -14px rgba(0, 0, 0, 0.5);
  }
  .theme-menu[hidden] { display: none; }

  .theme-option {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    width: 100%;
    padding: 0.45rem 0.55rem;
    border: 0;
    border-radius: 0.5rem;
    background: transparent;
    color: var(--fg-muted);
    font-size: 0.85rem;
    text-align: left;
    cursor: pointer;
    transition: color 0.15s ease, background 0.15s ease;
  }
  .theme-option-icon { display: inline-flex; line-height: 0; }
  .theme-option:hover { background: var(--bg-elevated); color: var(--fg); }
  .theme-option[aria-checked="true"] { background: var(--bg-elevated); color: var(--fg); }
</style>

<script is:inline>
  (function () {
    const root = document.documentElement;
    const wrap = document.querySelector("[data-theme-switcher]");
    if (!wrap) return;
    const trigger = wrap.querySelector("[data-theme-trigger]");
    const menu = wrap.querySelector("[data-theme-menu]");
    const options = wrap.querySelectorAll(".theme-option");

    const refreshChecked = () => {
      const current = root.getAttribute("data-theme") ?? "system";
      options.forEach((opt) => {
        opt.setAttribute("aria-checked", opt.getAttribute("data-theme-set") === current ? "true" : "false");
      });
    };

    const onDocClick = (e) => { if (!wrap.contains(e.target)) close(); };
    const onKey = (e) => { if (e.key === "Escape") { close(); trigger.focus(); } };

    function open() {
      menu.hidden = false;
      trigger.setAttribute("aria-expanded", "true");
      document.addEventListener("click", onDocClick);
      document.addEventListener("keydown", onKey);
    }
    function close() {
      menu.hidden = true;
      trigger.setAttribute("aria-expanded", "false");
      document.removeEventListener("click", onDocClick);
      document.removeEventListener("keydown", onKey);
    }

    trigger.addEventListener("click", (e) => {
      e.stopPropagation();
      if (menu.hidden) open();
      else close();
    });

    options.forEach((opt) => {
      opt.addEventListener("click", () => {
        const next = opt.getAttribute("data-theme-set");
        if (!next) return;
        root.setAttribute("data-theme", next);
        try { localStorage.setItem("bb-theme", next); } catch (e) {}
        refreshChecked();
        close();
        trigger.focus();
      });
    });

    refreshChecked();
  })();
</script>

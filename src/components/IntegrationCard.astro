---
import Icon from "~/components/Icon.astro";
import PreviewPlaceholder from "~/components/PreviewPlaceholder.astro";
import { catalog, previewUrl, statsFor, type Integration } from "~/lib/labs";

interface Props {
  item: Integration;
  index?: number;
}
const { item, index = 0 } = Astro.props;

const typeLabel = catalog.types.find((t) => t.id === item.type)?.label ?? item.type;
const langLabel = catalog.languages.find((l) => l.id === item.language)?.label ?? item.language;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
// previewUrl: explicit override → README-extracted image → upstream body
// image/video → og:image → null. `null` ⇒ render the placeholder gradient.
const customPreview = previewUrl(item, base);
// Detect video previews so we render a <video> tag instead of <img>. Catches
// both extension-only URLs (.mp4) and Webflow-style URLs that have query
// strings or fragments after the extension.
const isVideo = customPreview ? /\.(mp4|webm|mov|m4v)(?:[?#]|$)/i.test(customPreview) : false;

// Stats are first-party only — upstream integrations don't have a `repo`.
const stats = item.repo ? statsFor(item.id) : undefined;

const delay = `${Math.min(index, 7) * 60}ms`;
---
<a
  href={item.url}
  target="_blank"
  rel="noopener"
  class="card-glow group relative flex h-full flex-col overflow-hidden rounded-[var(--radius-card)] border"
  style={`border-color: var(--border); background: var(--bg-card); animation: var(--animate-fade-up); animation-delay: ${delay};`}
  data-card
  data-id={item.id}
  data-categories={item.categories.join(" ")}
  data-type={item.type}
  data-language={item.language}
  data-search={`${item.title} ${item.tagline} ${item.description} ${item.tags.join(" ")} ${item.repo ?? item.source ?? ""}`.toLowerCase()}
  data-featured={item.featured ? "1" : "0"}
  data-track="card_click"
  data-track-id={item.id}
  data-track-type={item.type}
  data-track-language={item.language}
  data-track-source={item.repo ? "labs" : "upstream"}
>
  <div class="card-preview" aria-hidden="true">
    {customPreview ? (
      isVideo ? (
        <video
          src={customPreview}
          autoplay
          loop
          muted
          playsinline
          preload="metadata"
        />
      ) : (
        <img src={customPreview} alt="" loading="lazy" decoding="async" />
      )
    ) : (
      <PreviewPlaceholder />
    )}
    {item.featured && (
      <span class="card-badge card-badge-featured">★ Featured</span>
    )}
    {stats?.stars != null && stats.stars > 0 && (
      <span class="card-badge card-badge-stars">★ {stats.stars}</span>
    )}
  </div>

  <div class="flex flex-1 flex-col gap-3 p-4 md:p-5">
    <div class="flex items-start gap-3">
      <div
        class="flex size-9 shrink-0 items-center justify-center rounded-lg"
        style="background: linear-gradient(135deg, color-mix(in oklab, var(--color-red-50) 22%, transparent), color-mix(in oklab, var(--color-purple-70) 22%, transparent)); color: var(--icon-on-surface);"
      >
        <Icon name={item.icon ?? "sparkle"} size={18} />
      </div>
      <div class="min-w-0 flex-1">
        <h3 class="truncate font-display text-base font-semibold leading-tight md:text-lg">{item.title}</h3>
        <p class="line-clamp-2 text-[13px]" style="color: var(--fg-muted);">{item.tagline}</p>
      </div>
    </div>

    <div class="flex flex-wrap items-center gap-1.5">
      <span class="chip">{typeLabel}</span>
      <span class="chip">{langLabel}</span>
    </div>
  </div>
</a>

<style>
  /* Solid theme-aware background — transparent PNGs (like MLflow's logo) get
     a clean, predictable backdrop instead of the previous red/purple gradient
     bleeding through. Opaque images (CVAT card, README screenshots) cover it. */
  .card-preview {
    position: relative;
    aspect-ratio: 16 / 6;
    width: 100%;
    overflow: hidden;
    background: var(--preview-bg);
  }
  .card-preview :global(img),
  .card-preview :global(video),
  .card-preview :global(.placeholder) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 0%;
    display: block;
    transition: transform 0.55s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  a:hover .card-preview :global(img),
  a:hover .card-preview :global(video),
  a:focus-visible .card-preview :global(img),
  a:focus-visible .card-preview :global(video) {
    transform: scale(1.04);
  }
  .card-badge {
    position: absolute;
    top: 0.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    z-index: 2;
  }
  .card-badge-featured {
    left: 0.5rem;
    background: var(--color-red-50);
    color: white;
    box-shadow: 0 4px 12px -4px rgba(226, 6, 38, 0.5);
  }
  .card-badge-stars {
    right: 0.5rem;
    background: var(--bg-elevated);
    color: var(--fg);
    border: 1px solid var(--border-strong);
    backdrop-filter: blur(10px);
  }
</style>

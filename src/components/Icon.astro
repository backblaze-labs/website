---
interface Props {
  name: string;
  class?: string;
  size?: number;
}

const { name, class: className = "", size = 20 } = Astro.props;
---
<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  {name === "sparkle" && (
    <>
      <path d="M12 3v6M12 15v6M3 12h6M15 12h6M5.6 5.6l4.2 4.2M14.2 14.2l4.2 4.2M5.6 18.4l4.2-4.2M14.2 9.8l4.2-4.2" />
    </>
  )}
  {name === "flow" && (
    <>
      <circle cx="5" cy="6" r="2.5" />
      <circle cx="19" cy="6" r="2.5" />
      <circle cx="12" cy="18" r="2.5" />
      <path d="M7 7.5 11 16M17 7.5 13 16" />
    </>
  )}
  {name === "wrench" && (
    <path d="M14.7 6.3a4 4 0 0 0-5.4 5.4L3 18l3 3 6.3-6.3a4 4 0 0 0 5.4-5.4l-2.5 2.5-2.5-.8-.8-2.5z" />
  )}
  {name === "notebook" && (
    <>
      <rect x="5" y="3" width="14" height="18" rx="2" />
      <path d="M9 3v18M5 7h2M5 11h2M5 15h2M5 19h2" />
    </>
  )}
  {name === "code" && (
    <>
      <path d="m9 8-4 4 4 4M15 8l4 4-4 4M14 4l-4 16" />
    </>
  )}
  {name === "bot" && (
    <>
      <rect x="4" y="8" width="16" height="12" rx="3" />
      <path d="M12 4v4" />
      <circle cx="9" cy="14" r="1" fill="currentColor" />
      <circle cx="15" cy="14" r="1" fill="currentColor" />
      <path d="M2 14h2M20 14h2" />
    </>
  )}
  {name === "star" && (
    <path d="m12 3 2.6 6 6.4.6-4.9 4.4 1.5 6.5L12 17l-5.6 3.5 1.5-6.5L3 9.6 9.4 9z" />
  )}
  {name === "server" && (
    <>
      <rect x="3" y="4" width="18" height="6" rx="1.5" />
      <rect x="3" y="14" width="18" height="6" rx="1.5" />
      <circle cx="7" cy="7" r="0.5" fill="currentColor" />
      <circle cx="7" cy="17" r="0.5" fill="currentColor" />
    </>
  )}
  {name === "search" && (
    <>
      <circle cx="11" cy="11" r="7" />
      <path d="m20 20-3.5-3.5" />
    </>
  )}
  {name === "github" && (
    <path stroke="none" fill="currentColor" d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.9 1.52 2.34 1.08 2.91.83.09-.65.35-1.08.63-1.33-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.03a9.5 9.5 0 0 1 5 0c1.91-1.3 2.75-1.03 2.75-1.03.55 1.38.2 2.4.1 2.65.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.69-4.57 4.94.36.31.68.92.68 1.85v2.74c0 .27.18.58.69.48A10 10 0 0 0 12 2z" />
  )}
  {name === "external" && (
    <>
      <path d="M14 4h6v6M20 4 10 14M9 4H5a1 1 0 0 0-1 1v14a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-4" />
    </>
  )}
  {name === "x" && (
    <path d="M6 6l12 12M18 6 6 18" />
  )}
  {name === "filter" && (
    <path d="M4 5h16l-6 8v6l-4-2v-4z" />
  )}
  {name === "arrow-right" && (
    <path d="M5 12h14M13 6l6 6-6 6" />
  )}
  {name === "flame" && (
    <path stroke="none" fill="currentColor" d="M12 2c.6 1.4 1.5 3.4 1.5 5.6 0 4.6-7.5 5.9-7.5 11.3 0 4.1 3 6.6 5.9 6.6 2.6 0 4-1.6 4-3.9 0-1.9-.9-3.4-.9-4.7 0-2 2.2-3.3 3.4-4.1-.4.5-.9 1.7-.9 2.4 0 4 5.6 6.2 5.6 11.2 0 3.6-2.7 5.1-4.7 5.1-1.7 0-3.8-1.1-3.8-4 0-2.4 1.5-2.5 1.5-5.2 0-1.5-1.1-3.3-1.1-4.9 0-2.1 2.2-4 3.4-4.6z" />
  )}
</svg>

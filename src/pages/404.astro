---
import BaseLayout from "~/layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<BaseLayout title="Not found">
  <section class="container-page py-24 text-center">
    <p class="font-mono text-sm" style="color: var(--fg-dim);">404</p>
    <h1 class="mt-2 font-display text-4xl font-semibold tracking-tight md:text-5xl">
      Lost in the buckets
    </h1>
    <p class="mt-3" style="color: var(--fg-muted);">
      That page isn't here. Head back to the integrations gallery.
    </p>
    <a href={base || "/"} class="btn-primary mt-8">Back home</a>
  </section>
</BaseLayout>

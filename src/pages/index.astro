---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Hero from "~/components/Hero.astro";
import Gallery from "~/components/Gallery.astro";
import { catalog, sortIntegrations } from "~/lib/labs";

// Schema.org ItemList positions need to match what users see in the gallery —
// otherwise Google's sitelinks may surface integrations in a different order
// than the rendered DOM. Pre-sort with the same comparator the gallery uses
// (featured → has-preview → alphabetical).
const orderedItems = sortIntegrations(catalog.integrations);
---
<BaseLayout
  itemList={{
    name: "Backblaze Labs Integrations",
    items: orderedItems,
  }}
>
  <Hero />
  <Gallery />
</BaseLayout>

---
import BaseLayout from "~/layouts/BaseLayout.astro";
import IntegrationCard from "~/components/IntegrationCard.astro";
import Icon from "~/components/Icon.astro";
import { catalog, sortIntegrations } from "~/lib/labs";

export function getStaticPaths() {
  return catalog.categories.map((c) => ({
    params: { id: c.id },
    props: {
      category: c,
      items: catalog.integrations.filter((i) => i.categories.includes(c.id)),
    },
  }));
}

const { category, items } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
// Same sort order as the main gallery: featured → has-real-image → alpha.
const sorted = sortIntegrations(items);
---
<BaseLayout
  title={`${category.label} integrations`}
  description={`${items.length} open source ${category.label} projects working with Backblaze B2 — from Backblaze Labs and the community.`}
  itemList={{
    name: `${category.label} integrations on Backblaze Labs`,
    items: sorted,
  }}
>
  <section class="container-page py-10 md:py-14">
    <a
      href={`${base || "/"}#integrations`}
      class="inline-flex items-center gap-1.5 text-sm transition hover:text-[var(--color-red-50)]"
      style="color: var(--fg-muted);"
    >
      <Icon name="arrow-right" size={14} class="rotate-180" /> All integrations
    </a>
    <h1 class="mt-6 font-display text-3xl font-semibold tracking-tight md:text-5xl">
      <span class="hero-mark">{category.label}</span>
    </h1>
    <p class="mt-3 text-lg" style="color: var(--fg-muted);">
      {items.length} {items.length === 1 ? "integration" : "integrations"} in this category.
    </p>

    <div class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {sorted.map((item, i) => <IntegrationCard item={item} index={i} />)}
    </div>

    <div class="mt-12 flex flex-wrap gap-2">
      <span class="text-sm" style="color: var(--fg-dim);">Browse other categories:</span>
      {catalog.categories.filter((c) => c.id !== category.id).map((c) => (
        <a href={`${base}/category/${c.id}`} class="chip transition hover:border-[var(--border-strong)]">{c.label}</a>
      ))}
    </div>
  </section>
</BaseLayout>

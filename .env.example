# Backblaze Labs Website — environment template
# Copy to `.env` for local dev, or set as repo secrets / Actions env for production.
# All variables exposed to the browser MUST be prefixed PUBLIC_ (Astro convention).

# Google Analytics 4 measurement ID. Leave blank to disable.
# Example: G-XXXXXXXXXX
PUBLIC_GA_ID=

# Enable GA4 debug_mode (logs to DebugView). Set to "true" only for non-prod.
PUBLIC_GA_DEBUG=

# Google Tag Manager container ID. Leave blank to disable. Can be set in addition
# to PUBLIC_GA_ID (events forward to both).
# Example: GTM-XXXXXXX
PUBLIC_GTM_ID=

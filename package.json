{
  "name": "@backblaze-labs/website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "biome lint --error-on-warnings .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "astro check",
    "validate": "node scripts/validate.mjs",
    "sync-stats": "node scripts/sync-stats.mjs",
    "sync-previews": "node scripts/sync-previews.mjs",
    "sync-links": "node scripts/sync-links.mjs",
    "sync": "node scripts/sync.mjs",
    "discover": "node scripts/discover.mjs",
    "merge-discovered": "node scripts/merge-discovered.mjs",
    "gen-assets": "node scripts/gen-og-assets.mjs",
    "docs:lint": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#dist\" \"#.astro\"",
    "spellcheck": "cspell --no-progress --no-must-find-files",
    "checks": "npm run lint && npm run format:check && npm run typecheck && npm run validate && npm run docs:lint && npm run spellcheck",
    "fix": "biome check --write . && npm run typecheck && npm run validate",
    "prepare": "simple-git-hooks || true"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run checks"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^7.0.0",
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^7.0.0",
    "satori": "^0.26.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^26.1.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "cspell": "^10.0.1",
    "markdownlint-cli2": "^0.23.0",
    "sharp": "^0.35.3",
    "simple-git-hooks": "^2.13.1"
  },
  "overrides": {
    "vite": "^8.0.13",
    "esbuild": "^0.28.1",
    "fast-uri": "^3.1.2",
    "js-yaml": "^4.2.0",
    "markdown-it": "^14.2.0",
    "yaml": "^2.9.0"
  }
}

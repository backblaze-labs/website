{
  "name": "@backblaze-labs/website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "biome lint --error-on-warnings .",
    "lint:fix": "biome lint --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "typecheck": "astro check",
    "validate": "node scripts/validate.mjs",
    "sync-stats": "node scripts/sync-stats.mjs",
    "sync-previews": "node scripts/sync-previews.mjs",
    "sync-links": "node scripts/sync-links.mjs",
    "sync": "node scripts/sync.mjs",
    "discover": "node scripts/discover.mjs",
    "merge-discovered": "node scripts/merge-discovered.mjs",
    "docs:lint": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#dist\" \"#.astro\"",
    "spellcheck": "cspell --no-progress --no-must-find-files",
    "checks": "npm run lint && npm run format && npm run typecheck && npm run validate && npm run docs:lint && npm run spellcheck",
    "fix": "biome check --write . && npm run typecheck && npm run validate",
    "prepare": "simple-git-hooks || true"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run checks"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/mdx": "^4.2.4",
    "@fontsource/dm-sans": "^5.1.0",
    "@fontsource/space-grotesk": "^5.1.0",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.1.1",
    "astro": "^5.6.1",
    "satori": "^0.12.0",
    "tailwindcss": "^4.1.1",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@types/node": "^22.10.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "cspell": "^9.4.1",
    "markdownlint-cli2": "^0.18.1",
    "simple-git-hooks": "^2.11.1"
  }
}
